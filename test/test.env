#!/usr/bin/env bash
# Single definition of the e2e test username.
# Sourced by non-privileged orchestrators and entry points.
# Privileged leaf scripts receive this as an argument and verify it
# independently via target-user-guards.sh.

TEST_USER="pen-test-user"

# PEN_TEST_FRESH_USER (optional, default unset)
# Set to "1" to delete and recreate the test user on every run.
# When unset, the test user is retained across runs for faster iteration.
# The pre-commit hook sets this to ensure full isolation before commits.
